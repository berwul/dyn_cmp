<?xml version="1.0" ?>
<robot name="simple">
    <link name="link_0">
        <inertial>
            <mass value="0.01"/>
            <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
            <inertia ixx="0.01" ixy="0.01" ixz="0.01" iyy="0.0" iyz="0.0" izz="0.0"/>
        </inertial>
    </link>
    <link name="link_1">
        <inertial>
            <mass value="1.0"/>
            <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
            <inertia ixx="0.01" ixy="0.0001" ixz="0.0001" iyy="0.01" iyz="0.0001" izz="0.01"/>
        </inertial>
    </link>
    <link name="link_2">
        <inertial>
            <mass value="1.0"/>
            <origin rpy="0 0 0" xyz="0.0 0.0 0.1"/>
            <inertia ixx="0.01" ixy="0.0001" ixz="0.0" iyy="0.01" iyz="0.0001" izz="0.01"/>
        </inertial>
    </link>
    <link name="link_3">
        <inertial>
            <mass value="1.0"/>
            <origin rpy="0 0 0" xyz="0.0 0.0 0.125"/>
            <inertia ixx="0.001" ixy="0.0001" ixz="0.0001" iyy="0.001" iyz="0.0001" izz="0.001"/>
        </inertial>
    </link>
    <link name="link_4">
        <inertial>
            <mass value="0.1"/>
            <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
            <inertia ixx="0.0001" ixy="0.00001" ixz="0.00001" iyy="0.0001" iyz="0.00001" izz="0.0001"/>
        </inertial>
    </link>
    <link name="link_5">
        <inertial>
            <mass value="0.1"/>
            <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
            <inertia ixx="0.0001" ixy="0.00001" ixz="0.00001" iyy="0.0001" iyz="0.00001" izz="0.0001"/>
        </inertial>
    </link>

    <link name="link_6">
        <inertial>
            <mass value="0.01"/>
            <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
            <inertia ixx="0.0001" ixy="0.00001" ixz="0.00001" iyy="0.0001" iyz="0.00001" izz="0.0001"/>
        </inertial>
    </link>

    <joint name="joint_1" type="revolute">
        <origin rpy="0 0 0" xyz="0 0 0.0"/>
        <parent link="link_0"/>
        <child link="link_1"/>
        <axis xyz="0 0 1"/>
        <limit effort="87" lower="-3.14" upper="3.14" velocity="2.1750"/>
    </joint>
    <joint name="joint_2" type="revolute">
        <origin rpy="0 0 0" xyz="0 0 0.0"/>
        <parent link="link_1"/>
        <child link="link_2"/>
        <axis xyz="0 1 0"/>
        <limit effort="87" lower="-3.14" upper="3.14" velocity="2.1750"/>
    </joint>
    <joint name="joint_3" type="revolute">
        <origin rpy="0 0 0" xyz="0 0 0.4"/>
        <parent link="link_2"/>
        <child link="link_3"/>
        <axis xyz="0 1 0"/>
        <limit effort="87" lower="-3.14" upper="3.14" velocity="2.1750"/>
    </joint>

    <joint name="joint_4" type="revolute">
        <origin rpy="0 0 0" xyz="0 0 0.0"/>
        <parent link="link_3"/>
        <child link="link_4"/>
        <axis xyz="0 0 1"/>
        <limit effort="87" lower="-3.14" upper="3.14" velocity="2.1750"/>
    </joint>

    <joint name="joint_5" type="revolute">
        <origin rpy="0 0 0" xyz="0 0 0.25"/>
        <parent link="link_4"/>
        <child link="link_5"/>
        <axis xyz="0 1 0"/>
        <limit effort="87" lower="-3.14" upper="3.14" velocity="2.1750"/>
    </joint>

    <joint name="joint_6" type="revolute">
        <origin rpy="0 0 0" xyz="0 0 0.05"/>
        <parent link="link_5"/>
        <child link="link_6"/>
        <axis xyz="0 0 1"/>
        <limit effort="87" lower="-3.14" upper="3.14" velocity="2.1750"/>
    </joint>
</robot>